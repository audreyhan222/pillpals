# Copy to `.env` in this directory (do not commit `.env`).
# Run the API from `backend/` so this file is picked up.

# Firebase Admin SDK JSON (download from Firebase Console → Project settings → Service accounts).
# Prefer a filesystem path (keeps secrets out of the shell history):
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/your-adminsdk-xxxxx.json

# Alternative: paste the entire JSON as a single line (CI / containers):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
