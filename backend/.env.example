# Copy to `.env` in this directory (do not commit `.env`).
# Run the API from `backend/` so this file is picked up.

# Firebase Admin SDK JSON (download from Firebase Console → Project settings → Service accounts).
# Prefer a filesystem path (keeps secrets out of the shell history):
FIREBASE_SERVICE_ACCOUNT_PATH=/absolute/path/to/your-adminsdk-xxxxx.json

# Alternative: paste the entire JSON as a single line (CI / containers):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# OpenAI: medication label extraction for POST /scan-medication (set in `backend/.env`, do not commit).
# OPENAI_API_KEY=sk-...
# Optional (default gpt-4.1-mini):
# OPENAI_MODEL=gpt-4.1-mini

# Debug/testing only (disabled by default):
# If set, POST /scan-medication will always return this as the medication name.
# SCAN_MEDICATION_FORCE_NAME=Bobby joe
# Optional debug overrides:
# SCAN_MEDICATION_FORCE_DOSAGE=10 mL
# SCAN_MEDICATION_FORCE_INSTRUCTIONS=by mouth every 6 hours
